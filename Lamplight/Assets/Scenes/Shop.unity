  m_Script: {fileID: 11500000, guid: cf03c665d3246f34ea3fecae3b87a155, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ShopManager
  UIdeck: []
  EmptyUIcard: {fileID: 5353659238691074865, guid: ce21ffaee05b111478adf7f617e91aad, type: 3}
  shopCard: {fileID: 1597536464043359019, guid: a036032900724ca44b83ee89eaf8fb50, type: 3}
  deckPanel: {fileID: 971274866}
  shopPanel: {fileID: 695913169}
  textBox: {fileID: 1068032272}
  dialogue: {fileID: 341954053}
  harkerLines:
  - 'Ah! Young Jonathan, so nice to see you again. Please take what you need, it''s
    my honor to serve such a pure soul as yourself. '
  frankensteinLines:
  - Victor, we are allies but your convictions are...  Just don't make the same mistakes
    I did, alright?
  jekyllLines:
  - Salutations Dr. Jekyll! I hope you have been keeping well. How is the old ball
    and chain? Apologies, apologies, I didn't mean to demean Hyde.
  - Welcome Mr. Hyde, it is always nice to have such famous customers. You make that
    Ripper fellow seem like a school boy.
  dorianLines:
  - Greetings, my detested apprentice. You know, out of all my life you are my greatest
    regret. Just buy something.
  - I hate you...
  - Your lucky I am on a leash, or you would die where you stand, murderer.
  - You turned your back on humanity years ago. You are no better than the Count.
  sorrows: {fileID: 461654075}
  canvas: {fileID: 1155561645}
